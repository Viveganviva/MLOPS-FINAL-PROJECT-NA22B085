  "panels": [
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "line", "lineInterpolation": "linear", "lineWidth": 2, "fillOpacity": 10, "showPoints": "never" }
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "id": 1,
      "targets": [
        {
          "expr": "sum(rate(regime_predictions_total[5m])) by (regime_type)",
          "legendFormat": "{{regime_type}}",
          "refId": "A"
        }
      ],
      "title": "Prediction Rate",
      "type": "timeseries"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": { "defaults": { "unit": "ms" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "id": 2,
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(regime_prediction_latency_milliseconds_bucket[5m])) by (le, regime_type))",
          "legendFormat": "p50 {{regime_type}}",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(regime_prediction_latency_milliseconds_bucket[5m])) by (le, regime_type))",
          "legendFormat": "p95 {{regime_type}}",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(regime_prediction_latency_milliseconds_bucket[5m])) by (le, regime_type))",
          "legendFormat": "p99 {{regime_type}}",
          "refId": "C"
        }
      ],
      "title": "Inference Latency",
      "type": "timeseries"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": { "defaults": { "min": 0, "max": 1 }, "overrides": [] },
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 8 },
      "id": 3,
      "targets": [
        { "expr": "regime_model_confidence_score{regime_type=\"trend\"}", "legendFormat": "trend", "refId": "A" },
        { "expr": "regime_model_confidence_score{regime_type=\"vol\"}", "legendFormat": "vol", "refId": "B" },
        { "expr": "regime_model_confidence_score{regime_type=\"bull_bear\"}", "legendFormat": "bull_bear", "refId": "C" }
      ],
      "title": "Model Confidence",
      "type": "gauge"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 8 },
      "id": 4,
      "targets": [
        {
          "expr": "topk(10, regime_data_drift_kl_score)",
          "legendFormat": "{{regime_type}} / {{feature_name}}",
          "refId": "A"
        }
      ],
      "title": "Drift Scores",
      "type": "timeseries"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": { "defaults": { "unit": "percent" }, "overrides": [] },
      "gridPos": { "h": 7, "w": 8, "x": 0, "y": 15 },
      "id": 5,
      "targets": [
        { "expr": "system_cpu_usage_percent", "legendFormat": "CPU", "refId": "A" }
      ],
      "title": "CPU Usage",
      "type": "timeseries"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": { "defaults": { "unit": "megabytes" }, "overrides": [] },
      "gridPos": { "h": 7, "w": 8, "x": 8, "y": 15 },
      "id": 6,
      "targets": [
        { "expr": "system_memory_usage_mb", "legendFormat": "Memory MB", "refId": "A" }
      ],
      "title": "Memory Usage",
      "type": "timeseries"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 5 }] }
        },
        "overrides": []
      },
      "gridPos": { "h": 7, "w": 8, "x": 16, "y": 15 },
      "id": 7,
      "targets": [
        { "expr": "api_error_rate_percent", "legendFormat": "Error Rate", "refId": "A" }
      ],
      "title": "API Error Rate",
      "type": "stat"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "gridPos": { "h": 7, "w": 24, "x": 0, "y": 22 },
      "id": 8,
      "targets": [
        { "expr": "increase(regime_retraining_triggered_total[24h])", "legendFormat": "{{trigger_reason}}", "refId": "A" }
      ],
      "title": "Retraining Events",
      "type": "barchart"
    }
