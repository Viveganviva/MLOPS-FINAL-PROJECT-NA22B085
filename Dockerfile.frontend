FROM nginx:alpine

COPY frontend/ /usr/share/nginx/html/

RUN printf 'server {\n\
    listen 80;\n\
    server_name localhost;\n\
    root /usr/share/nginx/html;\n\
    index index.html;\n\
    location = /pipeline {\n\
        try_files /pipeline.html =404;\n\
    }\n\
    location / {\n\
        try_files $uri $uri.html $uri/ /index.html;\n\
    }\n\
}\n' > /etc/nginx/conf.d/default.conf

EXPOSE 80
